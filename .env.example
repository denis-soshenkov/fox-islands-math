# ============================================================
# Скопируйте в .env и заполните. .env не коммитится (.gitignore).
#
# ВАЖНО: web-конфиг Firebase и Google Client ID — НЕ секреты,
# они заполняются прямо в js/config.js (см. README).
# Здесь — только то, что действительно секретно: доступ к серверу.
# ============================================================

# --- Docker (локально или на сервере) ---
# Порт, на котором игра будет доступна: http://localhost:8080
GAME_PORT=8080

# --- Деплой на собственный сервер game.eropulsars.com ---
# Используется скриптом ./deploy.sh и GitHub Actions
# (в Actions задаются как Secrets: DEPLOY_HOST, DEPLOY_USER,
#  DEPLOY_PATH, DEPLOY_SSH_KEY — приватный ключ целиком).
DEPLOY_HOST=game.eropulsars.com
DEPLOY_USER=
DEPLOY_PATH=/opt/fox-islands
# путь к приватному SSH-ключу для локального deploy.sh
DEPLOY_KEY_FILE=~/.ssh/fox_islands_deploy

# Первичная настройка по паролю (используется один раз, чтобы поставить ключ):
# VPS_USER=
# VPS_PASS=
